# ─────────────────────────────────────────────────────────────────────────────
# Email Indexer — environment variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# Variables already exported in your shell always take priority over this file.
# ─────────────────────────────────────────────────────────────────────────────


# ── Article page scraping ─────────────────────────────────────────────────────
# Get a key at https://firecrawl.dev
# Without it, scraping falls back to requests + BeautifulSoup (still works).
# FIRECRAWL_API_KEY=fc-your-key-here


# ── Semantic search / embeddings ──────────────────────────────────────────────
# Which backend to use for generating article embeddings.
# Options: sentence_transformers | openai | none
EMBEDDING_BACKEND=sentence_transformers

# sentence-transformers model — only used when EMBEDDING_BACKEND=sentence_transformers
# Downloaded once (~80 MB) to your local Hugging Face cache, then reused.
# "all-MiniLM-L6-v2"   → 384-dim, fast, good quality  ← recommended
# "all-mpnet-base-v2"  → 768-dim, slower, higher accuracy
EMBEDDING_MODEL=all-MiniLM-L6-v2

# OpenAI — only used when EMBEDDING_BACKEND=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small


# ── Data directory ────────────────────────────────────────────────────────────
# Where articles_index.json and embeddings.npy are stored.
# Defaults to ./data/ (a subfolder next to this file).
# Uncomment and set an absolute path to store data elsewhere.
# EMAIL_INDEXER_DATA_DIR=/path/to/your/data
